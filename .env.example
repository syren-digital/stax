# Database
DATABASE_URL="postgresql://user:password@localhost:5432/stax?schema=public"

# Redis (Upstash)
REDIS_URL="https://your-upstash-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# EODHD Market Data API (free tier — https://eodhd.com)
# Omit or set to "placeholder" to use mock data in development
EODHD_API_KEY="your-eodhd-api-key"

# Clerk Auth
CLERK_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_..."

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID_STARTER=""
STRIPE_PRICE_ID_GROWTH=""
STRIPE_PRICE_ID_PRO=""

# App
NEXT_PUBLIC_APP_URL="https://app.stax.id.au"
